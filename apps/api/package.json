{
  "name": "@veyracast/api",
  "version": "1.0.0",
  "private": true,
  "description": "VeyraCast API — API-first social content agent, multi-provider AI (Claude default), scheduling, dashboard",
  "main": "build/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "start": "tsc && pnpm run postbuild && node build/index.js",
    "build": "tsc && pnpm run postbuild",
    "postbuild": "copyfiles -u 3 src/Agent/characters/*.json build/Agent/characters && copyfiles -u 2 src/db/schema.sql build/db",
    "train:link": "tsc && node build/Agent/training/WebsiteScraping.js",
    "train:audio": "tsc && node build/Agent/training/TrainWithAudio.js",
    "train:youtube": "tsc && node build/Agent/training/youtubeURL.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check:env": "node scripts/check-env.js",
    "setup": "node scripts/setup.js",
    "db:migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.114.0",
    "@google/genai": "^1.52.0",
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "csv-parser": "^3.2.1",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "instagram-private-api": "^1.46.1",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "moment": "^2.30.1",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "openai": "^6.49.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "proxy-chain": "^3.0.0",
    "puppeteer": "^25.2.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "readline-sync": "^1.4.10",
    "request": "^2.88.2",
    "request-promise": "^4.2.6",
    "socket.io": "^4.8.3",
    "textract": "^2.5.0",
    "twitter-api-v2": "^1.29.0",
    "user-agents": "^2.1.130",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@veyracast/tsconfig": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.1.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/readline-sync": "^1.4.8",
    "@types/request": "^2.48.13",
    "@types/request-promise": "^4.1.51",
    "@types/textract": "^2.4.5",
    "@types/user-agents": "^1.0.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0",
    "@types/supertest": "^6.0.3",
    "ts-jest": "^29.4.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
