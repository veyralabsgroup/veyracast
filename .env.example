# ==================== Server ====================
# Port the API server listens on (default: 3000)
PORT=3000

# Secret used to sign express-session cookies — change this before deploying!
SESSION_SECRET=change_me_before_deploying

# Environment: development | production
NODE_ENV=development

# ==================== Instagram ====================
IGusername=your_instagram_username
IGpassword=your_instagram_password

Xusername=your_twitter_username
Xpassword=your_twitter_password

# Twitter API v2 (required for /api/post-tweet and Twitter engagement routes)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# PostgreSQL (local dev default — works with docker compose or a local install)
# Docker:  postgresql://postgres:postgres@localhost:5432/veyracast_ai_agent
# Local:   postgresql://YOUR_USER@localhost:5432/veyracast_ai_agent
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veyracast_ai_agent
DB_REQUIRED=false

# Gemini API key(s)
GEMINI_API_KEY=your_primary_gemini_api_key
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2

# Optional: locale-specific ad/sponsored markers (comma-separated)
IG_AD_MARKERS=sponsored,paid partnership,paid partnership with
IG_AD_BUTTON_MARKERS=learn more,shop now,sign up,install now,get offer,subscribe,book now

# Optional: run Instagram agent loop automatically
IG_AGENT_ENABLED=false
IG_AGENT_INTERVAL_MS=30000
IG_RUN_PROFILE=standard
IG_MAX_POSTS_PER_RUN=20
IG_ACTION_DELAY_MIN_MS=5000
IG_ACTION_DELAY_MAX_MS=10000
IG_COOLDOWN_MINUTES=60
IG_COMMENT_ALLOWLIST=
IG_COMMENT_DENYLIST=
IG_COMMENT_SENTIMENT=any
IG_COMMENT_MIN_LENGTH=
IG_COMMENT_MAX_LENGTH=

# Optional: daily limit for IG actions (likes/comments). 0 = unlimited
IG_DAILY_MAX_ACTIONS=0

# Optional: logging backend ("winston" or "console")
LOGGER=console
TRAIN_MAX_FILE_MB=10
TRAIN_DRY_RUN=false
# Max pages to crawl during website training
TRAIN_MAX_CRAWL_PAGES=50

# ==================== API Rate Limiting ====================
# Customize rate limits for different endpoint types
# Format: RATE_LIMIT_<TYPE>_WINDOW_MS (time window) and RATE_LIMIT_<TYPE>_MAX (max requests)

# Login attempts: prevent brute force attacks
# Default: 5 attempts per 15 minutes per IP
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5

# Authenticated actions (interact, post-photo, etc.)
# Default: 10 requests per minute per user
RATE_LIMIT_ACTION_WINDOW_MS=60000
RATE_LIMIT_ACTION_MAX=10

# Direct messages: stricter to prevent spam
# Default: 3 DMs per minute per user
RATE_LIMIT_DM_WINDOW_MS=60000
RATE_LIMIT_DM_MAX=3

# Scraping operations: resource intensive
# Default: 2 scrapes per 5 minutes per user
RATE_LIMIT_SCRAPE_WINDOW_MS=300000
RATE_LIMIT_SCRAPE_MAX=2

# General API requests (catch-all)
# Default: 60 requests per minute per IP
RATE_LIMIT_GENERAL_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=60
